# Environment (controls dev features: skip login button, etc.)
# Set to 'production' to hide dev features while testing in Expo Go
EXPO_PUBLIC_NODE_ENV=development

# API Base URL
EXPO_PUBLIC_BACKEND_API_URL=http://192.168.1.9:8080

# Cognito Auth URL (single source)
# Keep domain/client_id/response_type/scope here.
# Do NOT include redirect_uri here; it is set by runtime in authService (web: current origin, native: Linking URL).
EXPO_PUBLIC_COGNITO_URL=https://us-east-19aokpqzo1.auth.us-east-1.amazoncognito.com/login?client_id=661fm3mj7s5qcmoldri1mem9sr&response_type=code&scope=email+openid+profile
